// Bubble Sort 

void swap(int *x, int *y)
{
	int tmp = *x;
	*x = *y;
	*y = tmp;
}
void bubble_sort(int x[], int n)
{
  int i,j;
  int flag = 0;
   for (i=n-1; i>0; i--)
   {
     for (j=0; j<i; j++)
     if (x[j] > x[j+1])
     {
       swap(&x[j],&x[j+1]);
       flag = 1;
     }
     if (flag == 0) return;
   }
}





// Quick Sort
int partition( int a[], int l, int r)
{
   int pivot, i, j, t;
   pivot = a[l];
   i = l;
   j = r+1;
   while( 1) {
          do {
              ++i;
             } while(a[i]<=pivot && i<=r);
          do {
              --j;
             } while( a[j] > pivot );
          if( i >= j ) break;
          t = a[i];
          a[i] = a[j];
          a[j] = t;
   }
   t = a[l];
   a[l] = a[j];
   a[j] = t;
   return j;
}

#include <stdio.h>
void quickSort( int[], int, int);
