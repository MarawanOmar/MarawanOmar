// insertionSort

void insertionSort (int list[], int size)
{
	int i,j,item;

	for (i=1; i<size; i++)
	{
		item = list[i] ;
		for (j=i-1; (j>=0)&& (list[j] > item); j--)
			list[j+1] = list[j];
		list[j+1] = item ;
	}
}


